{
	"name": "@snar-internal/tests",
	"type": "module",
	"scripts": {
		"build": "wireit",
		"test": "wireit",
		"serve": "wireit"
	},
	"wireit": {
		"build": {
			"command": "tsc --pretty",
			"clean": "if-file-deleted",
			"files": [
				"src/**/*.ts",
				"tsconfig.json"
			],
			"output": [
				"test.js"
			]
		},
		"test": {
			"command": "node test.js",
			"dependencies": [
				"build"
			]
		},
		"serve": {
			"command": "vite",
			"dependencies": [
				"build"
			]
		}
	},
	"dependencies": {
		"@snar/lit": "^1.2.0",
		"lit": "^2.7.4",
		"snar": "^2.1.5"
	}
}
