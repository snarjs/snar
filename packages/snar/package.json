{
  "name": "snar",
  "version": "2.1.2",
  "main": "./out/reactive-object.js",
  "module": "./out/reactive-object.js",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "serve": "vite --host --open /dev/",
    "build": "wireit",
    "test": "wireit"
  },
  "exports": {
    ".": {
      "types": "./out/reactive-object.d.ts",
      "default": "./out/reactive-object.js"
    },
    "./lib/localstorage.js": {
      "types": "./out/lib/localstorage.d.ts",
      "default": "./out/lib/localstorage.js"
    }
  },
  "wireit": {
    "build": {
      "dependencies": [
        "build:ts"
      ]
    },
    "build:ts": {
      "command": "tsc --pretty",
      "clean": "if-file-deleted",
      "files": [
        "src/**/*.ts",
        "tsconfig.json"
      ],
      "output": [
        "out/**/*.{js,js.map,d.ts,d.ts.map}",
        "tsconfig.tsbuildinfo"
      ]
    },
    "test": {
      "command": "wtr",
      "files": [
        "web-test-runner.config.js"
      ],
      "dependencies": [
        "build:ts"
      ]
    }
  },
  "devDependencies": {
    "vite": "^4.3.4"
  },
  "files": [
    "/out/",
    "!/out/test/"
  ]
}
